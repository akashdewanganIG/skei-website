# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Connection string used by Drizzle for both the public enquiry form and the
# admin dashboard. Use the pooled connection string if your provider has one.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Public website ──────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Admin dashboard (/skei-admin) ───────────────────────────────────────────
# Session signing secret (server-only). Generate: node scripts/hash-password.mjs --secret
AUTH_SECRET=

# Two accounts. Generate each hash: node scripts/hash-password.mjs "your-password"
ADMIN_USERNAME=admin
ADMIN_NAME=Administrator
ADMIN_PASSWORD_HASH=

STAFF_USERNAME=staff
STAFF_NAME=SKEI Staff
STAFF_PASSWORD_HASH=

# (Legacy — no longer used after the move to PostgreSQL/Drizzle.)
# LEADS_SCRIPT_URL=
# LEADS_API_SECRET=
