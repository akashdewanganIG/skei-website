# ── Public website ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Admin dashboard (/skei-admin) ───────────────────────────────────────────
# Session signing secret (server-only). Generate: node scripts/hash-password.mjs --secret
AUTH_SECRET=

# Two accounts. Generate each hash: node scripts/hash-password.mjs "your-password"
ADMIN_USERNAME=admin
ADMIN_NAME=Administrator
ADMIN_PASSWORD_HASH=

STAFF_USERNAME=staff
STAFF_NAME=SKEI Staff
STAFF_PASSWORD_HASH=

# Google Apps Script endpoint + shared secret (must match Apps Script API_SECRET).
LEADS_SCRIPT_URL=
LEADS_API_SECRET=
