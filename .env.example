# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Connection string used by Drizzle for both the public enquiry form and the
# SKEI Portal. Use the pooled connection string if your provider has one.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Public website ──────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Server-only key used to verify enquiry form reCAPTCHA tokens.
RECAPTCHA_SECRET_KEY=

# ── SKEI Portal (/skei-portal) ──────────────────────────────────────────────
# Session signing secret (server-only). Generate: node scripts/hash-password.mjs --secret
AUTH_SECRET=

# (Legacy — no longer used after the move to PostgreSQL/Drizzle.)
# LEADS_SCRIPT_URL=
# LEADS_API_SECRET=
